# Repo root — read by Astro via vite.envDir (site/astro.config.mjs).
# Copy to .env and edit for local overrides.
# Site defaults (Astro PUBLIC_* — baked in at build time)
PUBLIC_SITE_NAME=vmattoo.dev
PUBLIC_TAB_TITLE=Vaibhav on HTTPS
PUBLIC_DEFAULT_SCHEME=green
PUBLIC_DEFAULT_MODE=dark

# Waline self-hosted commenting (auto-generated by deploy/bootstrap.sh
# on first setup; do not edit unless you know what you are doing).
# WALINE_JWT_TOKEN must be a long random secret. bootstrap.sh writes one to
# ${DEPLOY_DIR}/.env on the VM; for local dev you can leave it blank
# (comments will be disabled).
WALINE_JWT_TOKEN=
WALINE_AUTHOR_EMAIL=you@example.com

# Optional SMTP for comment notification emails. Leave unset to disable.
# Example for Gmail:
#   WALINE_SMTP_SERVICE=Gmail
#   WALINE_SMTP_USER=you@gmail.com
#   WALINE_SMTP_PASS=<app password>
WALINE_SMTP_SERVICE=
WALINE_SMTP_USER=
WALINE_SMTP_PASS=

# Override only if you want a non-default subdomain. Defaults to
# https://comments.${SITE_DOMAIN}. Used at build time by the site.
PUBLIC_WALINE_SERVER_URL=

# --- Stirling-PDF ---
# Initial admin login. Auto-generated by deploy/bootstrap.sh on first
# deploy and printed to the bootstrap log; persisted in /opt/personal-website/.env
# on the VM (mode 0600). After first login, change the password via the
# Stirling-PDF UI; the env values become irrelevant at that point.
STIRLING_ADMIN_USERNAME=admin
STIRLING_ADMIN_PASSWORD=change-me-generated-on-bootstrap
