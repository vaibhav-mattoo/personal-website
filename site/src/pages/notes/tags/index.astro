---
import Base from '../../../layouts/Base.astro';
import TerminalPrompt from '../../../components/TerminalPrompt.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');
const counts = new Map<string, number>();
for (const note of notes) {
	for (const tag of note.data.tags) {
		counts.set(tag, (counts.get(tag) ?? 0) + 1);
	}
}
const tags = [...counts.entries()].sort(([a], [b]) => a.localeCompare(b));
---

<Base title="Tags">
	<header class="head">
		<h1>Tags</h1>
		<p>Every tag used across notes, with how many entries carry it.</p>
	</header>

	<TerminalPrompt command="ls tags/" />

	<ul class="list">
		{
			tags.map(([tag, count]) => (
				<li>
					<a href={`/notes/tags/${encodeURIComponent(tag)}/`}>
						<span class="list__title">{tag}</span>
						<span class="list__count">{count}</span>
					</a>
				</li>
			))
		}
	</ul>
</Base>

<style>
	.head {
		margin: 2rem 0 1.5rem;
	}
	.head h1 {
		margin: 0 0 0.5rem;
		color: var(--accent);
		font-family: var(--font-body);
		font-size: clamp(2rem, 5vw, 2.75rem);
	}
	.head p {
		margin: 0;
		color: var(--muted);
		font-family: var(--font-body);
	}
	.list {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.list a {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.2rem;
		padding: 1rem 0;
		border-bottom: 1px solid var(--border);
		color: var(--fg);
		text-decoration: none;
	}
	.list a:hover .list__title {
		color: var(--accent);
	}
	.list__title {
		font-family: var(--font-body);
		font-weight: 600;
	}
	.list__count {
		font-family: var(--font-display);
		font-size: 0.85rem;
		color: var(--muted);
	}
</style>
