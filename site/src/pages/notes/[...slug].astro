---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import readingTime from 'reading-time';
import Base from '../../layouts/Base.astro';
import NoteMeta from '../../components/NoteMeta.astro';
import Toc from '../../components/Toc.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import Backlinks from '../../components/Backlinks.astro';
import Comments from '../../components/Comments.astro';
import { getBacklinks } from '../../lib/backlinks';
import '../../styles/prose.css';

export async function getStaticPaths() {
	const notes = await getCollection('notes');
	return notes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}

interface Props {
	note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const { Content, headings } = await render(note);

const words = (note.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const stats = readingTime(note.body ?? '');
const minutes = Math.max(1, Math.ceil(stats.minutes));

const backlinks = await getBacklinks(note.id);
---

<Base title={note.data.title}>
	<ReadingProgress />

	<article class="note" data-pagefind-body>
		<header class="note-head">
			<h1>{note.data.title}</h1>
			<NoteMeta date={note.data.date} minutes={minutes} words={words} />
			{note.data.summary && <p class="note-head__summary">{note.data.summary}</p>}
		</header>

		<div class="note-layout">
			<div class="prose">
				<Content />
			</div>
			<Toc headings={headings} />
		</div>

		<p class="note__back"><a href="/notes/">← All notes</a></p>
	</article>

	<Backlinks links={backlinks} />
	<Comments />
</Base>

<script>
	import mediumZoom from 'medium-zoom';
	mediumZoom('.prose img', {
		margin: 24,
		background: 'rgba(0,0,0,0.85)',
	});
</script>

<style>
	.note {
		margin: 2rem 0;
		max-width: 56rem;
	}

	.note-head {
		margin: 0 0 1.5rem;
		max-width: 42rem;
	}

	.note-head h1 {
		margin: 0 0 0.5rem;
		color: var(--accent);
		font-family: var(--font-body);
		font-size: clamp(1.75rem, 4vw, 2.5rem);
	}

	.note-head__summary {
		margin: 0.5rem 0 0;
		color: var(--muted);
		font-style: italic;
	}

	.note-layout {
		display: grid;
		gap: 2rem;
	}

	@media (min-width: 64rem) {
		.note-layout {
			grid-template-columns: minmax(0, 1fr) 14rem;
			align-items: start;
		}
	}

	.prose {
		max-width: 42rem;
	}

	.note__back {
		margin-top: 2rem;
		max-width: 42rem;
		font-family: var(--font-display);
	}

	.note__back a {
		color: var(--muted);
		text-decoration: none;
	}

	.note__back a:hover {
		color: var(--accent);
	}
</style>
