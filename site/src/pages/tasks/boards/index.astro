---
import Base from '../../../layouts/Base.astro';
import TerminalPrompt from '../../../components/TerminalPrompt.astro';
import { publicBoards, fizzyLoginUrl } from '../../../config/public-boards';
---

<Base title="Boards">
	<header class="head">
		<h1>Boards</h1>
		<p>Read-only public views of what I'm working on.</p>
	</header>

	<TerminalPrompt command="ls boards/" />

	{
		publicBoards.length === 0 ? (
			<p class="empty">No public boards yet.</p>
		) : (
			<nav class="tiles">
				{publicBoards.map((b) => (
					<a class="tile" href={b.url} target="_blank" rel="noopener">
						<span class="tile__title">{b.title} ↗</span>
						{b.description && <span class="tile__desc">{b.description}</span>}
					</a>
				))}
			</nav>
		)
	}

	<p class="login">
		<a href={fizzyLoginUrl} target="_blank" rel="noopener">Fizzy login ↗</a>
	</p>

	<p class="back"><a href="/tasks/">← back to tasks</a></p>
</Base>

<style>
	.head {
		margin: 2rem 0 1rem;
	}

	.head h1 {
		margin: 0 0 0.5rem;
		color: var(--accent);
		font-family: var(--font-body);
		font-size: clamp(2rem, 5vw, 2.75rem);
	}

	.head p {
		margin: 0;
		color: var(--muted);
		font-family: var(--font-body);
	}

	.empty {
		color: var(--muted);
		font-style: italic;
		margin: 1rem 0;
	}

	.tiles {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
		gap: 0.5rem;
		margin: 0.25rem 0 1rem;
	}

	.tile {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.7rem 0.85rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		color: var(--fg);
		text-decoration: none;
		transition:
			border-color 0.15s,
			color 0.15s,
			background-color 0.15s;
	}

	.tile:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: var(--accent-soft);
	}

	.tile__title {
		font-family: var(--font-display);
		font-size: 0.9rem;
		font-weight: 600;
	}

	.tile__desc {
		font-family: var(--font-body);
		font-size: 0.82rem;
		color: var(--muted);
	}

	.tile:hover .tile__desc {
		color: var(--accent);
	}

	.login {
		margin: 1.5rem 0 0;
		font-family: var(--font-display);
		font-size: 0.8rem;
		color: var(--muted);
	}

	.login a {
		color: var(--muted);
		text-decoration: none;
		border-bottom: 1px dotted var(--muted);
	}

	.login a:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.back {
		margin-top: 2rem;
		font-family: var(--font-display);
	}

	.back a {
		color: var(--muted);
		text-decoration: none;
	}

	.back a:hover {
		color: var(--accent);
	}
</style>
