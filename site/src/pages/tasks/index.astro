---
import Base from '../../layouts/Base.astro';
import TerminalPrompt from '../../components/TerminalPrompt.astro';
import SectionTile from '../../components/SectionTile.astro';

const items = [
	{ label: 'Current tasks', href: '/tasks/boards/', external: false },
	{ label: 'Calendar', href: '/tasks/calendar/', external: false },
];
---

<Base title="Tasks">
	<header class="head">
		<h1>Tasks</h1>
		<p>Boards I'm working on and a calendar to book time.</p>
	</header>

	<TerminalPrompt command="ls tasks/" />

	<nav class="tiles">
		{
			items.map((i) =>
				i.external ? (
					<a class="tile-ext" href={i.href} target="_blank" rel="noopener">
						{i.label} ↗
					</a>
				) : (
					<SectionTile label={i.label} href={i.href} />
				),
			)
		}
	</nav>
</Base>

<style>
	.head {
		margin: 2rem 0 1rem;
	}

	.head h1 {
		margin: 0 0 0.5rem;
		color: var(--accent);
		font-family: var(--font-body);
		font-size: clamp(2rem, 5vw, 2.75rem);
	}

	.head p {
		margin: 0;
		color: var(--muted);
		font-family: var(--font-body);
	}

	.tiles {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(8.5rem, 1fr));
		gap: 0.5rem;
		margin: 0.25rem 0 1rem;
	}

	.tile-ext {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.55rem 0.7rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		font-family: var(--font-display);
		font-size: 0.82rem;
		color: var(--fg);
		text-decoration: none;
		transition:
			border-color 0.15s,
			color 0.15s,
			background-color 0.15s;
	}

	.tile-ext:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: var(--accent-soft);
	}
</style>

<script is:inline>
	// Warm the connection to cal.com when the user shows intent to visit
	// the Calendar page. One-shot per page load.
	let warmed = false;

	const warmCalCom = () => {
		if (warmed) return;
		warmed = true;

		const head = document.head;

		const preconnect = document.createElement('link');
		preconnect.rel = 'preconnect';
		preconnect.href = 'https://app.cal.com';
		head.appendChild(preconnect);

		const preload = document.createElement('link');
		preload.rel = 'preload';
		preload.as = 'script';
		preload.href = 'https://app.cal.com/embed/embed.js';
		preload.crossOrigin = 'anonymous';
		head.appendChild(preload);
	};

	const calendarTile = document.querySelector('a[href="/tasks/calendar/"]');
	if (calendarTile) {
		calendarTile.addEventListener('pointerenter', warmCalCom, { once: true });
		calendarTile.addEventListener('focus', warmCalCom, { once: true });
		calendarTile.addEventListener('touchstart', warmCalCom, { once: true, passive: true });
	}
</script>
