---
import Base from '../layouts/Base.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';

const status = 404;
const catUrl = `https://http.cat/${status}`;
---

<Base title="404">
	<section class="not-found">
		<TerminalPrompt command={`curl -s https://http.cat/${status}`} />
		<img
			class="not-found__cat"
			src={catUrl}
			alt="404 Not Found"
			width="750"
			height="600"
			loading="lazy"
			decoding="async"
		/>
		<a class="not-found__home" href="/">Go home</a>
	</section>
</Base>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		max-width: 42rem;
		margin: 0 auto;
		text-align: center;
	}

	.not-found :global(.prompt) {
		align-self: stretch;
		text-align: left;
	}

	.not-found__cat {
		width: min(100%, 750px);
		height: auto;
		border-radius: var(--radius);
		border: 1px solid var(--border);
	}

	.not-found__home {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.55rem 1.25rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		font-family: var(--font-display);
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--fg);
		text-decoration: none;
		transition:
			border-color 0.15s,
			color 0.15s,
			background-color 0.15s;
	}

	.not-found__home:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: var(--accent-soft);
	}
</style>
