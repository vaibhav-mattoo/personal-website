---
interface Props {
	date: Date;
	minutes: number;
	words: number;
}

const { date, minutes, words } = Astro.props;
---

<div class="meta">
	<time datetime={date.toISOString()}>{date.toLocaleDateString()}</time>
	<span class="dot">·</span>
	<span>{minutes} min read</span>
	<span class="dot">·</span>
	<span>{words.toLocaleString()} words</span>
</div>

<style>
	.meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-display);
		font-size: 0.85rem;
		color: var(--muted);
	}

	.dot {
		opacity: 0.5;
	}
</style>
