---
// Loaded only on note slug pages. The Waline client bundle (~53 KB gzip) is
// scoped to those pages by Astro's per-page bundling.
---

<section class="comments" aria-label="Comments">
	<div id="waline" class="waline"></div>
</section>

<script>
	import { init } from '@waline/client';
	import '@waline/client/style';

	const serverURL = import.meta.env.PUBLIC_WALINE_SERVER_URL;

	if (serverURL) {
		init({
			el: '#waline',
			serverURL,
			dark: 'html[data-mode="dark"]',
			path: window.location.pathname.replace(/\/$/, '') || '/',
			lang: 'en',
			meta: ['nick'],
			requiredMeta: ['nick'],
			locale: {
				nick: 'Name',
			},
			commentSorting: 'latest',
		});
	} else {
		const el = document.getElementById('waline');
		if (el) {
			el.textContent =
				'Comments are disabled: PUBLIC_WALINE_SERVER_URL is not set at build time.';
		}
	}
</script>

<style>
	.comments {
		margin: 3rem 0 1rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.comments {
		--waline-font-size: 1rem;
		--waline-theme-color: var(--accent);
		--waline-active-color: var(--accent);
		--waline-color: var(--fg);
		--waline-bg-color: var(--bg);
		--waline-bg-color-light: var(--accent-soft);
		--waline-bg-color-hover: var(--accent-soft);
		--waline-border-color: var(--border);
		--waline-disable-bg-color: var(--accent-soft);
		--waline-disable-color: var(--muted);
		--waline-code-bg-color: var(--bg);
		--waline-info-bg-color: var(--accent-soft);
		--waline-info-color: var(--muted);
		--waline-avatar-radius: 50%;
		--waline-border: 1px solid var(--border);
	}

	.comments :global(.wl-header) {
		display: flex;
		align-items: center;
		border-bottom: none;
		padding: 1.25rem 1rem;
		box-sizing: border-box;
	}

	.comments :global(.wl-header-item) {
		display: flex;
		align-items: center;
		flex: 1;
		width: 100%;
		gap: 1rem;
		padding-inline: 0.25rem;
	}

	.comments :global(.wl-header input),
	.comments :global(.wl-editor) {
		padding: 0.6rem 0.75rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		background: var(--bg);
		color: var(--fg);
		font-family: var(--font-body);
		font-size: 0.95rem;
		transition:
			border-color 0.15s,
			box-shadow 0.15s,
			background-color 0.15s;
	}

	.comments :global(.wl-header input::placeholder),
	.comments :global(.wl-editor::placeholder) {
		color: var(--muted);
	}

	.comments :global(.wl-header input:focus),
	.comments :global(.wl-editor:focus) {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 1px var(--accent);
	}

	.comments :global(.wl-header label) {
		display: flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: flex-end;
		min-width: 3.25rem;
		margin: 0;
		padding: 0 0.5rem 0 0;
		color: var(--accent);
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.95rem;
		line-height: 1;
		text-align: right;
		background: none;
		border: none;
	}

	.comments :global(.wl-header input) {
		flex: 1 1 auto;
		align-self: center;
		min-height: 2.75rem;
	}
</style>
