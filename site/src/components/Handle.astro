---
import { site } from '../config/site';
---

<a class="handle" href="/" aria-label="Home">{site.handle}</a>

<style>
	.handle {
		display: inline-flex;
		align-items: center;
		height: 38px;
		padding: 0 0.5rem;
		border-radius: var(--radius);
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 700;
		color: var(--fg);
		text-decoration: none;
	}

	.handle:hover {
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 8%, var(--bg));
	}
</style>
